---
interface Props {
  title: string;
  prompt?: string;
  accent?: string;
  defaultOpen?: boolean;
}

const {
  title,
  prompt,
  accent = 'var(--accent)',
  defaultOpen = false,
} = Astro.props;
---

<details class="worked-solution" open={defaultOpen} style={`--ws-accent: ${accent};`}>
  <summary class="worked-solution-summary">
    <span class="worked-solution-chip">Worked Solution</span>
    <span class="worked-solution-title">{title}</span>
  </summary>
  {prompt && <p class="worked-solution-prompt">{prompt}</p>}
  <div class="worked-solution-body">
    <slot />
  </div>
</details>

<style>
  .worked-solution {
    background: var(--surface-2);
    border: var(--border-default);
    border-left: 3px solid var(--ws-accent);
    border-radius: var(--radius-md);
    padding: 0;
    overflow: hidden;
  }

  .worked-solution + .worked-solution {
    margin-top: var(--space-3);
  }

  .worked-solution-summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-4) var(--space-5);
    user-select: none;
    background: color-mix(in srgb, var(--ws-accent) 6%, var(--surface-2));
  }

  .worked-solution-summary::-webkit-details-marker {
    display: none;
  }

  .worked-solution-summary::before {
    content: '▸';
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--ws-accent);
    transition: transform var(--duration-fast) var(--ease-out);
  }

  .worked-solution[open] .worked-solution-summary::before {
    transform: rotate(90deg);
  }

  .worked-solution-chip {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--ws-accent);
    background: color-mix(in srgb, var(--ws-accent) 12%, transparent);
    padding: 2px 8px;
    border-radius: var(--radius-sm);
    flex-shrink: 0;
  }

  .worked-solution-title {
    font-size: var(--text-sm);
    color: var(--ink-primary);
    font-weight: 600;
    line-height: var(--leading-normal);
  }

  .worked-solution-prompt {
    padding: var(--space-4) var(--space-5) 0;
    font-size: var(--text-sm);
    color: var(--ink-secondary);
    line-height: var(--leading-normal);
  }

  .worked-solution-body {
    padding: var(--space-4) var(--space-5) var(--space-5);
    font-size: var(--text-sm);
    color: var(--ink-secondary);
    line-height: var(--leading-relaxed);
  }
</style>
