---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/global.css';
import '../../styles/course.css';
import LessonPage from '../../components/course/LessonPage';
import GatePanel from '../../components/assessment/GatePanel';
import ShapeTrace from '../../components/interactive/ShapeTrace';
---

<BaseLayout title="Quiz: Dense Transformer Block">
  <LessonPage lessonId="Q-M4" client:load>

    <div class="lesson-section">
      <div class="section-label">Module Quiz</div>
      <h2 style="font-family: var(--font-display); font-size: var(--text-2xl); margin-bottom: var(--space-3);">Dense Transformer Block</h2>
      <p style="color: var(--ink-secondary);">
        This quiz covers everything from M4: layer structure, residuals, normalization, Q/K/V projections, positional encoding, causal attention, multi-head attention, FFN, and the full decoder block.
      </p>
      <p style="color: var(--ink-tertiary); font-size: var(--text-sm); margin-top: var(--space-2);">
        You need 80% or better to proceed.
      </p>
    </div>

    <div class="lesson-section">
      <div class="section-label">Shape Trace</div>
      <p style="font-size: var(--text-sm); color: var(--ink-secondary); margin-bottom: var(--space-3);">
        Before the multiple choice, trace shapes through one attention sub-layer. The model has 20 tokens, d_model=1024, n_heads=16, d_head=64.
      </p>
      <ShapeTrace
        client:load
        title="Attention sub-layer (20 tokens, d_model=1024, 16 heads)"
        steps={[
          { label: "Input hidden states", shape: [20, 1024] },
          { label: "After RMSNorm", shape: [20, 1024] },
          { label: "Q per head", description: "d_head=64", shape: [20, 64] },
          { label: "K per head", description: "d_head=64", shape: [20, 64] },
          { label: "Scores per head", description: "Q·Kᵀ", shape: [20, 20] },
          { label: "After W_O projection", description: "all heads → d_model", shape: [20, 1024] },
          { label: "After residual add", shape: [20, 1024] },
        ]}
      />
    </div>

    <div class="lesson-section">
      <GatePanel
        client:load
        lessonId="Q-M4"
        gateStrength="hard"
        passThreshold={0.8}
        questions={[
          {
            id: 'QM4-q1',
            type: 'single_choice',
            prompt: 'A 32-layer model processes a token. After all layers, the final hidden state still contains information from the original embedding. What mechanism makes this possible?',
            tag: 'reasoning',
            choices: [
              { id: 'a', text: 'RMSNorm preserves the original values by normalizing scale', isCorrect: false },
              { id: 'b', text: 'Residual connections — each layer adds its transform to the running sum, so original information carries through', isCorrect: true },
              { id: 'c', text: 'The embedding is re-read at every layer from a separate cache', isCorrect: false },
            ],
            explanation: 'Residual connections form a running sum: each layer adds its output to the input. Over 32 layers, the original embedding signal can survive because it is never overwritten — only added to. Without residuals, the original information would be repeatedly transformed and likely degraded.',
          },
          {
            id: 'QM4-q2',
            type: 'single_choice',
            prompt: 'In causal attention, what does the mask prevent?',
            tag: 'conceptual',
            choices: [
              { id: 'a', text: 'Tokens from attending to themselves', isCorrect: false },
              { id: 'b', text: 'Tokens from attending to future positions', isCorrect: true },
              { id: 'c', text: 'Tokens from attending to the first token', isCorrect: false },
            ],
            explanation: 'Causal masking ensures token i can only attend to positions 0..i, never to future positions. This enforces left-to-right generation.',
          },
          {
            id: 'QM4-q3',
            type: 'single_choice',
            prompt: 'If d_model = 512 and there are 8 attention heads, what is d_head?',
            tag: 'shape',
            choices: [
              { id: 'a', text: '64', isCorrect: true },
              { id: 'b', text: '512', isCorrect: false },
              { id: 'c', text: '4096', isCorrect: false },
            ],
            explanation: 'd_head = d_model / n_heads = 512 / 8 = 64. Each head operates in a 64-dimensional subspace.',
          },
          {
            id: 'QM4-q4',
            type: 'single_choice',
            prompt: 'If you removed all attention layers but kept the FFN layers and residual connections, what would the model lose?',
            tag: 'reasoning',
            choices: [
              { id: 'a', text: 'The ability to change the dimension of hidden states', isCorrect: false },
              { id: 'b', text: 'The ability for tokens to influence each other — each token would be processed in isolation', isCorrect: true },
              { id: 'c', text: 'The ability to apply nonlinear transformations', isCorrect: false },
            ],
            explanation: 'Attention is the only operation that mixes information between token positions. FFN operates per-token independently. Without attention, the model would process each token as if it were alone — no context, no word relationships, no sentence understanding.',
          },
          {
            id: 'QM4-q5',
            type: 'single_choice',
            prompt: 'What is the correct order of operations in a standard decoder block?',
            tag: 'conceptual',
            choices: [
              { id: 'a', text: 'FFN → Attention → Norm → Residual', isCorrect: false },
              { id: 'b', text: 'Norm → Attention → Residual → Norm → FFN → Residual', isCorrect: true },
              { id: 'c', text: 'Attention → FFN → Norm → Residual', isCorrect: false },
            ],
            explanation: 'The standard pre-norm decoder block: normalize, then attention with residual, then normalize again, then FFN with residual.',
          },
        ]}
      />
    </div>

  </LessonPage>
</BaseLayout>
