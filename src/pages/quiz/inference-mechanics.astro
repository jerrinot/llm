---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/global.css';
import '../../styles/course.css';
import LessonPage from '../../components/course/LessonPage';
import GatePanel from '../../components/assessment/GatePanel';
---

<BaseLayout title="Quiz: Inference Mechanics">
  <LessonPage lessonId="Q-M6" client:load>

    <div class="lesson-section">
      <div class="section-label">Module 6 Quiz</div>
      <p>
        This quiz covers the inference pipeline: prefill, decode, the KV cache, batching, continuous batching, and context scaling. You need 80% or better to proceed.
      </p>
    </div>

    <div class="lesson-section">
      <div class="section-label">Check Yourself</div>
      <GatePanel
        client:load
        lessonId="Q-M6"
        gateStrength="hard"
        passThreshold={0.8}
        questions={[
          {
            id: 'QM6-q1',
            type: 'single_choice',
            prompt: 'A user sends a 500-token prompt and requests a 100-token response. Which phase determines the time-to-first-token (TTFT) — the delay before any output appears?',
            tag: 'reasoning',
            choices: [
              { id: 'a', text: 'Prefill — the user waits while all 500 prompt tokens are processed before seeing any output', isCorrect: true },
              { id: 'b', text: 'Decode — generating 100 tokens takes longer than processing 500', isCorrect: false },
              { id: 'c', text: 'Neither — the total time is split evenly between prefill and decode', isCorrect: false },
            ],
            explanation: 'Prefill determines time-to-first-token: the user sees nothing until all 500 prompt tokens have been processed through every layer. After that, decode tokens stream out incrementally. The user perceives the prefill delay as "thinking time" before any response appears.',
          },
          {
            id: 'QM6-q2',
            type: 'single_choice',
            prompt: 'During decode, the new token computes Q but reads K and V from a cache. Why is Q not cached alongside K and V?',
            tag: 'reasoning',
            choices: [
              { id: 'a', text: 'Q is too large to cache efficiently', isCorrect: false },
              { id: 'b', text: 'Q is only needed for the current token — it asks "what am I looking for?" and is never reused by future tokens', isCorrect: true },
              { id: 'c', text: 'Q is always identical to K so caching it would be redundant', isCorrect: false },
            ],
            explanation: 'K and V are cached because future tokens need to attend to past K/V. But Q is the query for the current position only — future tokens will compute their own Q from their own hidden state. Past queries are never needed again, so caching them would waste memory.',
          },
          {
            id: 'QM6-q3',
            type: 'single_choice',
            prompt: 'A server is using continuous batching with 4 slots. Request R2 finishes while R1, R3, and R4 are still decoding. What happens next?',
            tag: 'conceptual',
            choices: [
              { id: 'a', text: 'The server waits for all requests to finish before accepting new ones', isCorrect: false },
              { id: 'b', text: 'R2\'s slot is immediately available for a new incoming request', isCorrect: true },
              { id: 'c', text: 'The server restarts all requests from scratch', isCorrect: false },
            ],
            explanation: 'Continuous batching fills empty slots immediately. When R2 completes, its slot and KV cache space are freed, and a new request can begin prefill in that slot without waiting for R1, R3, or R4 to finish.',
          },
          {
            id: 'QM6-q4',
            type: 'single_choice',
            prompt: 'During decode, the attention score vector for the new token has shape [1, n_past + 1] (where n_past is the number of previously cached tokens). If 500 tokens were cached before this step, what is the length of the score vector?',
            tag: 'shape',
            choices: [
              { id: 'a', text: '1', isCorrect: false },
              { id: 'b', text: '501', isCorrect: true },
              { id: 'c', text: 'd_model', isCorrect: false },
            ],
            explanation: 'n_past = 500 (tokens already in the cache). The new token\'s K/V are appended before the dot product, so the score vector has length n_past + 1 = 501 — one entry per cached token including the current one.',
          },
          {
            id: 'QM6-q5',
            type: 'single_choice',
            prompt: 'Why does doubling the context length more than double the total prefill time?',
            tag: 'conceptual',
            choices: [
              { id: 'a', text: 'Because the model weights are loaded twice', isCorrect: false },
              { id: 'b', text: 'Because FFN cost quadruples when tokens double', isCorrect: false },
              { id: 'c', text: 'Because attention cost scales quadratically with sequence length, so doubling tokens roughly quadruples the attention work', isCorrect: true },
              { id: 'd', text: 'Because the tokenizer is slower on longer inputs', isCorrect: false },
            ],
            explanation: 'During prefill, the attention score matrix has shape [n, n], so its cost scales as n squared. Doubling n quadruples attention work. FFN cost only doubles (linear in n). The combined effect is more than 2x total work.',
          },
        ]}
      />
    </div>

  </LessonPage>
</BaseLayout>
