---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/global.css';
import '../../styles/course.css';
import LessonPage from '../../components/course/LessonPage';
import GatePanel from '../../components/assessment/GatePanel';
---

<BaseLayout title="Quiz: Architecture Variants">
  <LessonPage lessonId="Q-M5" client:load>

    <div class="lesson-section">
      <div class="section-label">Module 5 Quiz</div>
      <p>
        This quiz covers all of Module 5: GQA/MQA, sliding-window attention, shared-KV layers, MoE routing, MoE aggregation, and heterogeneous architectures. You need 80% or better to proceed.
      </p>
    </div>

    <div class="lesson-section">
      <div class="section-label">Check Yourself</div>
      <GatePanel
        client:load
        lessonId="Q-M5"
        gateStrength="hard"
        passThreshold={0.8}
        questions={[
          {
            id: 'QM5-q1',
            type: 'single_choice',
            prompt: 'A model has 32 Q heads and 4 KV heads (GQA) with d_head=128. What is the K cache entry shape per token per layer?',
            tag: 'reasoning',
            choices: [
              { id: 'a', text: '[32, 128] — one K per Q head', isCorrect: false },
              { id: 'b', text: '[4, 128] — one K per KV head, each shared across 8 Q heads', isCorrect: true },
              { id: 'c', text: '[1, 128] — GQA shares a single K across all heads', isCorrect: false },
            ],
            explanation: 'In GQA, the KV cache stores entries per KV head, not per Q head. With 4 KV heads and d_head=128, each token contributes [4, 128] to the K cache. Each KV head is shared by a group of 32/4 = 8 Q heads. This is the memory-saving mechanism: 4 stored K vectors instead of 32.',
          },
          {
            id: 'QM5-q2',
            type: 'single_choice',
            prompt: 'In MoE, what does the router produce?',
            tag: 'conceptual',
            choices: [
              { id: 'a', text: 'A new hidden state for each token', isCorrect: false },
              { id: 'b', text: 'One score per expert for each token, used to select which experts run', isCorrect: true },
              { id: 'c', text: 'A compressed version of the KV cache', isCorrect: false },
            ],
            explanation: 'The router is a linear projection that produces one logit per expert. These scores determine which experts are selected via top-k.',
          },
          {
            id: 'QM5-q3',
            type: 'single_choice',
            prompt: 'A model uses SWA with window size w = 512 and has 24 SWA layers stacked. Approximately how many tokens back can information theoretically reach?',
            tag: 'math',
            choices: [
              { id: 'a', text: '512 tokens — each layer sees only its own window', isCorrect: false },
              { id: 'b', text: 'About 12,000 tokens — each layer extends the reach by w-1 through the residual stream', isCorrect: true },
              { id: 'c', text: 'Unlimited — stacking enough layers removes the window constraint entirely', isCorrect: false },
            ],
            explanation: 'Each SWA layer extends the indirect receptive field by w-1 positions through the residual stream. With 24 layers: 1 + 24 × 511 = 12,265 tokens. But this is indirect access — the signal degrades with distance compared to full attention.',
          },
          {
            id: 'QM5-q4',
            type: 'single_choice',
            prompt: 'Why do shared-KV layers reduce memory bandwidth during decode?',
            tag: 'conceptual',
            choices: [
              { id: 'a', text: 'They skip the FFN entirely', isCorrect: false },
              { id: 'b', text: 'They avoid loading W_K and W_V weights and writing new KV cache entries', isCorrect: true },
              { id: 'c', text: 'They use a smaller d_model', isCorrect: false },
            ],
            explanation: 'A shared-KV layer has no K or V weight matrices to load and writes nothing to the KV cache. It reads K/V from an earlier layer\'s cache, saving both the matmul compute and the memory bandwidth for weight loading and cache writes.',
          },
          {
            id: 'QM5-q5',
            type: 'single_choice',
            prompt: 'A MoE model has 64 experts with top-2 routing. During decode, how does this affect memory bandwidth compared to a dense model with the same per-token compute?',
            tag: 'reasoning',
            choices: [
              { id: 'a', text: 'Same bandwidth — only 2 experts run, so the same amount of weight data is loaded', isCorrect: false },
              { id: 'b', text: 'Higher bandwidth — all 64 experts\' weights must be in memory even though only 2 run per token, and different tokens may select different experts', isCorrect: true },
              { id: 'c', text: 'Lower bandwidth — MoE models are smaller than dense models', isCorrect: false },
            ],
            explanation: 'Although only 2 experts compute per token, the full 64-expert weight set must reside in memory. During batched decode, different tokens may route to different experts, requiring loading more distinct weight blocks than a dense model would. This makes MoE especially memory-bandwidth-sensitive during decode.',
          },
        ]}
      />
    </div>

  </LessonPage>
</BaseLayout>
